# https://gist.github.com/ffermi/cb6bfb01656c9d45c4eb54768b5d2699

@basePath = https://carburanti.mise.gov.it/ospzApi

# NB: In questo documento non sono censite le API protette (es: `{{basePath}}/management/...`).

###

# @name getBrands
GET {{basePath}}/registry/brands
Accept: application/json

### 

# @name getFuels
GET {{basePath}}/registry/fuels
Accept: application/json

###

# @name getHighways
GET {{basePath}}/registry/highway
Accept: application/json

###

# @name getProvinces
GET {{basePath}}/registry/province
Accept: application/json

###

# @name getRegions
GET {{basePath}}/registry/region
Accept: application/json

###

# @name getServiceAreaById
GET {{basePath}}/registry/servicearea/15350
Accept: application/json

###

# @name getTowns
GET {{basePath}}/registry/town?province=MI
Accept: application/json


###

# @name getAllLogo
GET {{basePath}}/registry/alllogos
Accept: application/json
//NB: image in base64

###

# @name getConventionList
GET {{basePath}}/registry/conventions
Accept: application/json

###

# @name getFlagList
GET {{basePath}}/registry/flags
Accept: application/json

###

# @name getServiceAreaNameList
GET {{basePath}}/registry/adsname?streetId=1
Accept: application/json

####

# @name getServicesList
GET {{basePath}}/registry/services
Accept: application/json

####

# @name getStationType
GET {{basePath}}/registry/stationtype
Accept: application/json

####

# @name getStreetList
GET {{basePath}}/registry/streets?tipoId=1
Accept: application/json

####

# @name getTipoDelegaList
GET {{basePath}}/registry/tipodelega
Accept: application/json

####

# @name getfuelTypeList
GET {{basePath}}/registry/fueltype?flagId=337
Accept: application/json

####

# @name searchByArea
POST {{basePath}}/search/area
Content-Type: application/json
Accept: application/json

{
  "region":19,
  "province":"MI",
  "town":"Arese",
  "fuelType":"1-x",
  "priceOrder":"desc"
}

####

# @name searchByHighway
POST {{basePath}}/search/highway
Content-Type: application/json
Accept: application/json

{
  "highwayId":"A4-8",
  "fuelType":"1-x",
  "priceOrder":"asc"
}

####

